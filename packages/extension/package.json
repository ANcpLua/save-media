{
  "name": "@savemedia/extension",
  "version": "0.0.5",
  "private": true,
  "description": "savemedia browser extension package for Chrome, Edge, and Firefox Desktop.",
  "license": "Apache-2.0",
  "author": "Alexander Nachtmann ANcpLua",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ANcpLua/save-media.git",
    "directory": "packages/extension"
  },
  "type": "module",
  "scripts": {
    "build": "node scripts/build-chrome.mjs",
    "build:chrome": "node scripts/build-chrome.mjs",
    "build:firefox": "node scripts/build-firefox.mjs",
    "build:all": "pnpm build:chrome && pnpm build:firefox",
    "zip": "pnpm build:all && node scripts/package.mjs",
    "dev": "SAVEMEDIA_BROWSER=chromium vite build --watch",
    "icons": "node scripts/generate-icons.mjs",
    "store:assets": "node scripts/store-assets.mjs",
    "lint:firefox": "pnpm build:firefox && web-ext lint --source-dir dist-firefox",
    "smoke:edge": "pnpm build:chrome && node scripts/smoke-edge.mjs",
    "smoke:firefox": "pnpm build:firefox && node scripts/smoke-firefox.mjs",
    "publish:chrome": "node scripts/publish-chrome.mjs",
    "publish:edge": "node scripts/publish-edge.mjs",
    "screenshots": "node scripts/screenshot/capture.mjs",
    "lint": "pnpm typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm test:e2e:chromium",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox-fixtures": "playwright test --project=firefox-fixtures",
    "test:e2e:headed": "playwright test --project=chromium --headed",
    "report:e2e": "playwright show-report playwright-report",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@savemedia/core": "workspace:*",
    "m3u8-parser": "^7.2.0",
    "mediabunny": "^1.45.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/chrome": "0.2.0",
    "@types/node": "22.19.19",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "autoprefixer": "10.5.0",
    "jsdom": "25.0.1",
    "postcss": "8.5.15",
    "selenium-webdriver": "4.44.0",
    "tailwindcss": "3.4.19",
    "vite": "5.4.21",
    "vitest": "1.6.1",
    "web-ext": "10.2.0"
  }
}
